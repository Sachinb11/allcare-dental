# ══════════════════════════════════════════════════════════
#  All Care Dental Clinic — Environment Variables
#  Copy to .env.local and fill in your real values
# ══════════════════════════════════════════════════════════

# ── Supabase (Database) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Email (Resend) ───────────────────────────────────────
# Get free key at resend.com (3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email addresses
CLINIC_EMAIL=pravinvaishya@yahoo.com
EMAIL_FROM=noreply@allcaredental.in     # Must be verified domain in Resend
                                        # OR use: onboarding@resend.dev (testing only)

# ── Admin Access ─────────────────────────────────────────
# Protects GET /api/appointments  — use a long random string
ADMIN_SECRET_KEY=generate-a-long-random-secret-here

# ── Site Config ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://allcare-dental.vercel.app
NEXT_PUBLIC_DOCTOR_WHATSAPP=917620750026

# ── Optional: Google Analytics ───────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
